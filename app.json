{
  "expo": {
    "name": "TDSS-MOBILE",
    "slug": "TDSS-MOBILE",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-full.png",
    "scheme": "tdssmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo-full.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B3551",
        "foregroundImage": "./assets/images/logo-full.png",
        "monochromeImage": "./assets/images/logo-full.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aissatoulamarana.TDSSMOBILE"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.ico"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B3551",
          "android": {
            "image": "./assets/images/logo-full.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f0cea4ec-8957-4363-be92-fbd389a71270"
      }
    }
  }
}
